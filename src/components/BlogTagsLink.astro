---
import type { Post, SelectProperty } from '../lib/interfaces.ts'
import { getTagLink } from '../lib/blog-helpers.ts'
import NoContents from './NoContents.astro'
import { getContentPosts } from '../lib/notion/client.ts'
import '../styles/notion-color.css'

export interface Props {
  heading: string
  tags: SelectProperty[]
  contentPosts?: Post[]
}

const { heading, tags, contentPosts: contentPostsProp } = Astro.props

const contentPosts =
  contentPostsProp !== undefined ? contentPostsProp : await getContentPosts()

interface TagHierarchy {
  baseTag: SelectProperty
  children: Map<string, SelectProperty>
}

// Notionの仕様に合わせて、親カテゴリを「ピンク色 (pink)」のものと定義する
const PARENT_COLOR = 'pink'

const hierarchy: Record<string, TagHierarchy> = {}

// 1. まず親カテゴリ（ピンク色）を登録する
tags.forEach((tag) => {
  if (tag.color === PARENT_COLOR) {
    hierarchy[tag.name] = {
      baseTag: tag,
      children: new Map(),
    }
  }
})

// 2. 記事についているタグから親子関係を導き出す
// 同一記事内に親タグ(pink)と子タグ(pink以外)が共存していれば紐付ける
contentPosts.forEach((post) => {
  const parentTags = post.Tags.filter((t) => t.color === PARENT_COLOR)
  const childTags = post.Tags.filter(
    (t) => t.color !== PARENT_COLOR && t.name !== 'Info'
  )

  parentTags.forEach((parent) => {
    if (hierarchy[parent.name]) {
      childTags.forEach((child) => {
        hierarchy[parent.name].children.set(child.name, child)
      })
    }
  })
})

const assignedChildNames = new Set<string>()

// 3. マップを配列に変換し、子カテゴリを名前順にソートする
const groupedTags = Object.values(hierarchy).map((group) => {
  const children = Array.from(group.children.values()).sort((a, b) =>
    a.name.localeCompare(b.name)
  )
  children.forEach((c) => assignedChildNames.add(c.name))
  return { baseTag: group.baseTag, children }
})

// 4. どの親カテゴリにも属さないタグ（ピンク色でもなく、親と一緒に使われたこともないタグ）を抽出
const standaloneTags = tags.filter(
  (tag) => tag.color !== PARENT_COLOR && !assignedChildNames.has(tag.name)
)

standaloneTags.forEach((tag) => {
  groupedTags.push({ baseTag: tag, children: [] })
})

// 5. 親カテゴリ名で全体をソート
groupedTags.sort((a, b) => a.baseTag.name.localeCompare(b.baseTag.name))
---

<div class="blog-tags-link">
  <h2>{heading}</h2>
  {
    tags.length === 0 ? (
      <NoContents contents={tags} />
    ) : (
      <ul class="tag-tree">
        {groupedTags.map((group) => (
          <li class="tag-group">
            {group.children.length > 0 ? (
              <details class="tag-details">
                <summary class={`tag-summary tag ${group.baseTag.color}`}>
                  <a href={getTagLink(group.baseTag.name)} class="summary-link">
                    {group.baseTag.name}
                  </a>
                </summary>
                <ul class="tag-children">
                  {group.children.map((child: SelectProperty) => {
                    return (
                      <li>
                        <a
                          href={getTagLink(child.name)}
                          class={`tag ${child.color}`}
                        >
                          {child.name}
                        </a>
                      </li>
                    )
                  })}
                </ul>
              </details>
            ) : (
              <a
                href={getTagLink(group.baseTag.name)}
                class={`tag ${group.baseTag.color} standalone-tag`}
              >
                {group.baseTag.name}
              </a>
            )}
          </li>
        ))}
      </ul>
    )
  }
</div>

<style>
  .blog-tags-link {
  }
  .blog-tags-link h2 {
    margin: 0;
    padding-left: 0.4rem;
    color: #777;
    font-size: 0.95rem;
  }
  .blog-tags-link ul {
    list-style-type: none;
    padding: 0;
    margin-top: 0.5rem;
    margin-block-end: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .blog-tags-link ul li {
    font-size: 0.9rem;
    line-height: 1.2rem;
  }

  /* タグの基本スタイル */
  .tag {
    display: inline-block;
    min-width: 0;
    border-radius: 3px;
    padding: 4px 8px;
    line-height: 1.2;
    color: rgb(50, 48, 44);
    background: rgba(227, 226, 224, 0.5);
    text-decoration: none;
  }

  .tag-group {
    display: block;
    margin-bottom: 0.4rem;
  }

  .standalone-tag {
    display: inline-block;
    margin-bottom: 2px;
  }

  /* アコーディオン (details/summary) スタイル */
  .tag-details {
    display: block;
    width: 100%;
  }

  /* summaryタグを装飾してタグのように見せる */
  .tag-summary {
    cursor: pointer;
    user-select: none;
    display: inline-flex;
    align-items: center;
    list-style: none; /* デフォルトの矢印を消す準備 */
    position: relative;
    padding-left: 20px; /* 矢印アイコン用スペース */
    margin-bottom: 4px;
    transition: background-color 0.2s ease;
  }

  /* summaryに付いているaタグはあくまで見出しのリンクとして装飾を消す */
  .summary-link {
    color: inherit;
    text-decoration: none;
  }

  .summary-link:hover {
    text-decoration: underline;
  }

  /* ウェブキット系ブラウザ用のアコーディオン矢印消去 */
  .tag-summary::-webkit-details-marker {
    display: none;
  }

  /* カスタムの開閉矢印を擬似要素で追加 */
  .tag-summary::before {
    content: '▶';
    position: absolute;
    left: 6px;
    font-size: 0.6rem;
    color: inherit;
    transition: transform 0.2s ease;
  }

  /* detailsが開いている時は矢印を下に向ける */
  .tag-details[open] .tag-summary::before {
    transform: rotate(90deg);
  }

  /* 子要素リストのスタイル */
  .tag-children {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    gap: 6px;
    padding-left: 12px;
    margin-top: 0.3rem !important;
    margin-bottom: 0.2rem !important;
    border-left: 1px dashed var(--sss-border, #ccc);
  }

  .tag-children li {
    display: inline-block;
  }

  .tag-children a {
    display: inline-block;
    font-size: 0.85rem;
  }
</style>
